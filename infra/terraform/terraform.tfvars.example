# Copy this file to terraform.tfvars and fill in your values.
# Never commit terraform.tfvars — it contains secrets.

compartment_id      = "ocid1.compartment.oc1..your-compartment-ocid"
availability_domain = "Uocm:PHX-AD-1"
region              = "us-phoenix-1"
environment         = "production"
site_domain         = "alreadyherellc.com"
instance_shape      = "VM.Standard.A1.Flex"
instance_ocpus      = 1
instance_memory_gb  = 6
data_volume_gb      = 50
ssh_public_key      = "ssh-ed25519 AAAA... your-key-here"
repo_url            = "https://github.com/quantam101/already-here-llc.git"
compose_branch      = "main"
