# Copy to /etc/already-here/hermes-runner.env on the Oracle VM.
# Never commit the real file with tokens.

# Required authenticated Git remote with write access.
# HERMES_REPO_URL=https://x-access-token:<TOKEN>@github.com/quantam101/already-here-llc.git
HERMES_REPO_URL=

HERMES_RUNNER_BRANCH=main
HERMES_RUNNER_REMOTE=origin
HERMES_RUNNER_SLEEP_SECONDS=300
