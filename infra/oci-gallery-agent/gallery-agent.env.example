# Already Here OCI Gallery Agent environment file.
# Copy to /etc/already-here/gallery-agent.env on the Oracle VM.
# Never commit the real file with tokens.

# Required: authenticated Git remote with write access.
# Recommended PAT-backed HTTPS format:
# GALLERY_REPO_URL=https://x-access-token:<TOKEN>@github.com/quantam101/already-here-llc.git
GALLERY_REPO_URL=

# Branch to update.
GALLERY_GIT_BRANCH=main
GALLERY_GIT_REMOTE=origin

# Approved local photo folder on the OCI VM.
# Google Drive/rclone sync should mirror approved photos into this folder only.
GALLERY_LOCAL_SOURCE_DIR=/opt/already-here-gallery/source

# Rotation control.
GALLERY_ROTATION_DAYS=21
GALLERY_PUBLISH_LIMIT=6
GALLERY_SLEEP_SECONDS=21600
GALLERY_FORCE_ROTATION=false

# Default website copy for rotated photos.
GALLERY_DEFAULT_TITLE=Field execution example
GALLERY_DEFAULT_CATEGORY=Project work
GALLERY_DEFAULT_DESCRIPTION=Approved project photo from the rotating gallery source.
GALLERY_COMMIT_PREFIX=rotate project gallery

# Optional Google Drive sync via rclone.
# Configure rclone remote separately with: rclone config
# Example remote/path: alreadyhere-drive:Already Here LLC/Website Gallery/Approved
RCLONE_REMOTE=alreadyhere-drive
RCLONE_SOURCE_PATH=Already Here LLC/Website Gallery/Approved
RCLONE_DESTINATION=/opt/already-here-gallery/source
RCLONE_SYNC_FLAGS=--copy-links --create-empty-src-dirs --fast-list --transfers=4 --checkers=8
