# ProfitEngine runtime environment
NODE_ENV=production
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000

# REQUIRED: Content generation (Groq inference)
GROQ_API_KEY=

# REQUIRED: GitHub publishing / repo writes
GITHUB_TOKEN=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=
GITHUB_BRANCH=main

# Optional: Dev.to publishing
DEVTO_API_KEY=

# Optional: Hashnode publishing
HASHNODE_TOKEN=
HASHNODE_PUBLICATION_ID=

# Optional: Medium publishing
MEDIUM_TOKEN=

# Optional: Alert email (Gmail App Password for nodemailer)
ALERT_EMAIL=
GMAIL_APP_PASSWORD=

# Content generation schedule (cron syntax)
# Default: daily at 7 AM and 7 PM
CONTENT_CRON_SCHEDULE=0 7,19 * * *

# Filesystem publisher: path relative to profitengine/ dir
CONTENT_OUTPUT_DIR=../content/blog

# Number of posts to generate per run
POSTS_PER_RUN=1
