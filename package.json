{
  "name": "already-here-llc",
  "version": "1.1.0-ai-agent-revenue",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint app components lib tests scripts tailwind.config.ts next.config.mjs postcss.config.js eslint.config.mjs --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:regression && npm run test:dispatch && npm run test:daily-command && npm run test:revenue-command && npm run test:revenue-pipeline && npm run test:local-revenue-radar && npm run test:ai-agent && npm run test:revenue-mesh && npm run test:level4",
    "test:regression": "node scripts/regression-config-check.mjs",
    "test:dispatch": "node --experimental-strip-types --import ./tests/register-next-alias.mjs tests/dispatch-contract.test.mjs",
    "test:daily-command": "node --experimental-strip-types --import ./tests/register-next-alias.mjs tests/daily-command-core.test.mjs && node --experimental-strip-types --import ./tests/register-next-alias.mjs tests/daily-command-super-ai.test.mjs",
    "test:revenue-command": "node --experimental-strip-types --import ./tests/register-next-alias.mjs tests/revenue-command-spine.test.mjs && node --experimental-strip-types --import ./tests/register-next-alias.mjs tests/revenue-command-intake.test.mjs",
    "test:revenue-pipeline": "node scripts/revenue-pipeline-export.mjs --input data/revenue-pipeline.json --out .tmp/revenue-pipeline-test --format json",
    "test:local-revenue-radar": "node tests/local-revenue-radar.test.mjs",
    "test:ai-agent": "node --experimental-strip-types --import ./tests/register-next-alias.mjs tests/ai-agent-lead.test.mjs",
    "test:revenue-mesh": "node --experimental-strip-types --import ./tests/register-next-alias.mjs tests/revenue-mesh.test.mjs",
    "test:level4": "node --experimental-strip-types --import ./tests/register-next-alias.mjs tests/level4-resiliency.test.mjs",
    "revenue:export": "node scripts/revenue-pipeline-export.mjs --input data/revenue-pipeline.json --out exports --format csv",
    "revenue:export:json": "node scripts/revenue-pipeline-export.mjs --input data/revenue-pipeline.json --out exports --format json",
    "qa:content": "node scripts/a-plus-content-guard.mjs",
    "qa:live": "node scripts/live-smoke-test.mjs",
    "qa:intake": "node scripts/intake-contract-smoke.mjs",
    "qa:socrates": "node scripts/socrates-agent.mjs",
    "qa:redteam": "node scripts/redteam-agent.mjs",
    "qa:pareto": "node scripts/pareto-agent.mjs",
    "qa:seo": "node scripts/seo-route-audit.mjs",
    "qa:gate": "node scripts/quality-gate.mjs",
    "qa:classify": "node scripts/ci-failure-classifier.mjs",
    "qa:ecosystem": "node scripts/ecosystem-production-gate.mjs"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "next": "16.2.10",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "remark": "^15.0.1",
    "remark-html": "^16.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "@types/react": "18.2.66",
    "@types/react-dom": "18.2.22",
    "autoprefixer": "10.5.2",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.10",
    "postcss": "8.5.16",
    "tailwindcss": "3.4.13",
    "typescript": "7.0.2"
  }
}
