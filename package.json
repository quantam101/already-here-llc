  },
  "devDependencies": {
    "@types/node": "20.14.0",
    "@types/react": "18.2.66",
    "@types/react-dom": "18.2.22",
    "autoprefixer": "10.4.20",
    "eslint": "8.57.0",
    "eslint-config-next": "15.5.15",
    "postcss": "8.4.49",
    "tailwindcss": "3.4.13",
    "typescript": "5.5.4"
  }
