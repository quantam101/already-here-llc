# Public site (required)
NEXT_PUBLIC_SITE_URL=https://www.alreadyherellc.com

# Dispatch (required)
RESEND_API_KEY=
DISPATCH_FROM_EMAIL=dispatch@alreadyherellc.com
# Temporary destination inbox for production dispatch testing.
DISPATCH_TO_EMAIL=alreadyherellc@gmail.com

# Runtime
NODE_ENV=development

# Optional form provider
FORM_PROVIDER=
FORM_PROVIDER_API_KEY=
FORM_PROVIDER_FORM_ID=

# Analytics and monitoring
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# Optional future services
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ── ProfitEngine webhook integration ─────────────────────────────────────────
# Required for notifyDispatch() and notifyBlogPost() to call the ProfitEngine API.
# Generate PROFITENGINE_WEBHOOK_TOKEN with: openssl rand -hex 32
# The token must match PROFITENGINE_WEBHOOK_TOKEN set in the profitengine Vercel project.
# Variable: PROFITENGINE_URL            (e.g. https://profitengine-tau.vercel.app)
# Variable: PROFITENGINE_WEBHOOK_TOKEN  (encrypted — set in Vercel production env only)
