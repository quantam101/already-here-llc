{
  "schemaVersion": 1,
  "system": {
    "name": "LINDYMODE Hermes Agentic Operating System",
    "codename": "already-here-hermes-os",
    "operator": "Already Here LLC",
    "runtime": "oracle-cloud-infrastructure",
    "mode": "always-on-governed-autonomy",
    "principles": [
      "durable operations over temporary chat output",
      "approved-source publishing only",
      "no secrets in repository code",
      "auditable missions with hashed receipts",
      "safe failure with preserved production state",
      "human-controlled policy gates for public content",
      "Socratic review before high-risk claims or public production changes",
      "Pareto prioritization before expanding backlog or automation scope",
      "Red-team defensive review before trusting automation expansion"
    ]
  },
  "missionRegistry": {
    "gallery.rotate": {
      "description": "Rotate approved project-gallery photos into the website from the OCI approved source folder.",
      "entrypoint": "node scripts/oci-gallery-agent.mjs",
      "risk": "medium",
      "approvalRequired": false,
      "writes": ["data/gallery-manifest.json", "public/gallery/rotating/**"],
      "forbiddenInputs": ["Do Not Publish", "private archives", "client credentials", "medical or patient records", "license plates", "faces without approval", "badges", "visible serial numbers"],
      "receiptRequired": true,
      "defaultSchedule": { "checkEverySeconds": 21600, "rotationDays": 21 }
    },
    "health.check": {
      "description": "Verify Hermes OS configuration, manifest availability, repo state, and gallery agent prerequisites.",
      "entrypoint": "node scripts/hermes-agentctl.mjs health",
      "risk": "low",
      "approvalRequired": false,
      "writes": [],
      "receiptRequired": true
    },
    "socrates.review": {
      "description": "Run SOCRATES readiness review against public claims, conversion paths, operational risk, security posture, and maintainability.",
      "entrypoint": "node scripts/socrates-agent.mjs",
      "risk": "low",
      "approvalRequired": false,
      "writes": ["hermes/receipts/**"],
      "blocksOn": ["unsupported certification claims", "secret literals in source", "broken primary CTA paths", "public copy exposing internal strategy"],
      "receiptRequired": true
    },
    "pareto.prioritize": {
      "description": "Run PARETO leverage prioritization across open backlog items and produce top recommended actions.",
      "entrypoint": "node scripts/pareto-agent.mjs",
      "risk": "low",
      "approvalRequired": false,
      "writes": ["hermes/pareto-backlog.json", "hermes/receipts/**"],
      "receiptRequired": true
    },
    "redteam.review": {
      "description": "Run REDTEAM defensive adversarial review against source, automation, public claims, and runner safety.",
      "entrypoint": "node scripts/redteam-agent.mjs",
      "risk": "low",
      "approvalRequired": false,
      "writes": ["hermes/redteam-report.json", "hermes/receipts/**"],
      "blocksOn": ["secret literals", "arbitrary runner execution", "unsafe shell patterns", "unsupported public claims", "dead buyer routes"],
      "receiptRequired": true
    }
  },
  "policyGates": {
    "publicContent": {
      "default": "approved-folder-only",
      "requiresHumanApprovalFor": ["new client names", "new claims of certification", "case-study photos with identifiable details", "regulated or confidential environments"]
    },
    "gitWrites": {
      "defaultBranch": "main",
      "allowedPaths": ["data/**", "public/gallery/rotating/**", "hermes/receipts/**", "hermes/pareto-backlog.json", "hermes/redteam-report.json"],
      "preserveOnFailure": true
    }
  },
  "receipts": {
    "directory": "hermes/receipts",
    "hash": "sha256",
    "include": ["mission", "startedAt", "finishedAt", "status", "gitStatus", "changedFiles", "environmentSummary"]
  }
}
