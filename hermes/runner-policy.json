{
  "schemaVersion": 1,
  "runner": {
    "name": "Hermes OCI Shell Runner",
    "mode": "allowlisted-command-runner",
    "host": "oracle-cloud-infrastructure",
    "operator": "Already Here LLC"
  },
  "security": {
    "openShell": false,
    "arbitraryCommands": false,
    "secretsInRepo": false,
    "receiptsRequired": true,
    "defaultTimeoutSeconds": 900
  },
  "allowedCommands": {
    "health.check": { "description": "Run Hermes health check.", "command": ["node", "scripts/hermes-agentctl.mjs", "health"], "risk": "low" },
    "socrates.review": { "description": "Run SOCRATES readiness review.", "command": ["node", "scripts/socrates-agent.mjs"], "risk": "low" },
    "pareto.prioritize": { "description": "Run PARETO leverage prioritization.", "command": ["node", "scripts/pareto-agent.mjs"], "risk": "low" },
    "redteam.review": { "description": "Run REDTEAM defensive adversarial review.", "command": ["node", "scripts/redteam-agent.mjs"], "risk": "low" },
    "a-plus.content-guard": { "description": "Run A+ forbidden-content guard.", "command": ["node", "scripts/a-plus-content-guard.mjs"], "risk": "low" },
    "a-plus.live-smoke-test": { "description": "Run A+ live route smoke test.", "command": ["node", "scripts/live-smoke-test.mjs"], "risk": "low" },
    "a-plus.intake-contract-smoke": { "description": "Run A+ intake contract smoke test in dry-run mode by default.", "command": ["node", "scripts/intake-contract-smoke.mjs"], "risk": "low" },
    "gallery.rotate": { "description": "Run gallery rotation mission.", "command": ["node", "scripts/oci-gallery-agent.mjs"], "risk": "medium" },
    "drive.sync": { "description": "Sync approved Google Drive gallery folder into the OCI approved source folder.", "command": ["bash", "infra/oci-gallery-agent/sync-approved-drive.sh"], "risk": "medium" },
    "git.status": { "description": "Show repository status.", "command": ["git", "status", "--short"], "risk": "low" }
  },
  "forbidden": ["curl pipe shell", "wget pipe shell", "rm -rf /", "chmod 777", "printing environment secrets", "arbitrary bash command from queue", "network listener remote shell"],
  "queue": {
    "file": "hermes/runner-queue.json",
    "acceptedStatuses": ["queued"],
    "terminalStatuses": ["complete", "failed", "skipped", "rejected"]
  },
  "receipts": {
    "directory": "hermes/receipts",
    "hash": "sha256"
  }
}
